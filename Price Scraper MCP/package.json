{
  "name": "price-scraper-mcp",
  "version": "1.0.0",
  "description": "MCP Server for Home Improvement Price Scraping - Home Depot & Lowe's",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start:stdio": "node dist/index.js --transport stdio",
    "start:http": "node dist/index.js --transport http",
    "dev": "tsx src/index.ts --transport stdio",
    "dev:http": "tsx src/index.ts --transport http",
    "migrate": "tsx db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "start:lite": "node dist/index-lite.js",
    "dev:lite": "tsx src/index-lite.ts",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2",
    "playwright": "^1.50.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "pg": "^8.13.1",
    "ioredis": "^5.4.2",
    "bullmq": "^5.34.8",
    "express": "^4.21.2",
    "pino": "^9.6.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.11.11",
    "@types/express": "^5.0.0"
  }
}
