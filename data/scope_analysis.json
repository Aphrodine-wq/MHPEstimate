  "pricing_structure_patterns": {
    "estimate_format": "MHP uses a standardized Project Estimate document with line items. Supporting Excel estimation sheets are created alongside (e.g., 'MHP Patton Porch Project Estimate 09272024.xlsx'). A Project Estimate Binder (PDF) compiles estimate, scope, allowances, and timeline into one package.",
    "allowance_system": "MHP uses a 'Project Selection Allowances' worksheet (Excel) for client-selected materials. Observed examples: 'Project Selection Allowances - Tommy Patton Sept 27 2024.xlsx', 'Project Selection Allowances - Taylor Wall and Porch Jan 23 2025.xlsx', 'Brooke Fence Project Selection Allowances - Dec 16 2024.xlsx'. When clients exceed allowance budgets, an Allowance Overage Memo is issued.",
    "contract_types": {
      "fixed_price": "MHP Prime Construction Contract - standard for most residential projects",
      "cost_plus": "NMHP Prime Construction Cost Plus Contract - used for complex or uncertain-scope projects (e.g., Lance Felker, Lachlan McQueen Vet Clinic)",
      "fixed_with_allowances": "Fixed Cost with Allowances Disclosure Form - hybrid approach for projects with client-selected materials",
      "retainer": "Contract Retainer Agreement - initial engagement before full contract",
      "professional_services": "NMHP Professional Services Contract - for owners rep / consulting roles"
    },
    "market_fluctuation": "MHP uses a Market Fluctuation Clause (MFC) for materials susceptible to price volatility. Observed on commercial projects (Oxford Vet Clinic).",
    "project_timeline": "Separate Project Timeline worksheets (Excel) are created per project.",
    "draw_schedule": "Construction Draw Schedule used for larger projects; Draw Request Memos submitted for progress payments."
  },

  "document_workflow": {
    "typical_project_lifecycle": [
      "1. Project Intake form completed",
      "2. Initial meeting / budget discussion",
      "3. Scope of Services drafted (may go through RV1, RV2 revisions)",
      "4. Project Estimate created with supporting Excel estimation sheet",
      "5. Project Selection Allowances worksheet prepared",
      "6. Project Timeline worksheet created",
      "7. Estimate Binder compiled (PDF package)",
      "8. Contract executed (Prime Construction Contract or variant)",
      "9. Change Order Memos issued as needed during construction",
      "10. Allowance Overage Memos issued when client selections exceed budget",
      "11. Draw Request Memos for progress payments",
      "12. Project Progress Reports during construction",
      "13. Closing Project Report at completion"
    ],
    "revision_tracking": "Documents use FV (Final Version), RV/RV1/RV2 (Revision), and Draft suffixes",
    "company_evolution": "Document prefixes show company name evolution: DSC (2022) -> NMHP (2023-early 2024) -> MHP (mid 2024-present)"
  },

